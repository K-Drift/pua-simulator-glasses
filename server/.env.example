# ============================================================
# Rokid Volc RTC Backend · 环境变量样例
# 复制为 .env 后填入真实值（.env 已被 .gitignore 忽略，切勿提交）
# ============================================================

# ---- 图像场景理解 LLM（第一视角画面 → 行为分类）----
# 为空时 analysisStatus 返回 missing_config，场景兜底为「一个人的默认」
IMAGE_LLM_API_KEY=
IMAGE_LLM_PROVIDER=zhizengzeng
IMAGE_LLM_MESSAGES_URL=https://api.zhizengzeng.com/anthropic/v1/messages
IMAGE_LLM_MODEL=mimo-v2.5
# 兼容旧变量名（可选）：ZHIZENGZENG_API_KEY / MINIMAX_API_KEY / DEMO_IMAGE_LLM_API_KEY
DEMO_IMAGE_LLM_API_KEY=

# ---- TokenDance 卡通头像生成（打印头像 / 报告海报）----
TOKENDANCE_IMAGE_API_KEY=
TOKENDANCE_IMAGE_URL=https://tokendance.space/gateway/v1/images/generations
TOKENDANCE_IMAGE_MODEL=seedream-5.0-lite

# ---- MiniMax 像素人像转视频管线（minimax_pixel_i2v.py）----
MINIMAX_API_KEY=
MINIMAX_PLATFORM_API_BASE=https://api.minimaxi.com
MINIMAX_IMAGE_MODEL=image-01-live
MINIMAX_VIDEO_MODEL=MiniMax-Hailuo-2.3-Fast

# ---- 七牛 Kling 图生图测试（qiniu_kling_image_test.py）----
QNAIGC_API_KEY=

# ---- 服务端口（可选）----
# PORT=18091
